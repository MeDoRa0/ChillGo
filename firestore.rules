rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function crewPath(crewId) {
      return /databases/$(database)/documents/crews/$(crewId);
    }

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function membershipPath(membershipId) {
      return /databases/$(database)/documents/crew_memberships/$(membershipId);
    }

    function ownerMembershipPath(crewId, ownerId) {
      return membershipPath(crewId + '_' + ownerId);
    }

    function invitationPath(invitationId) {
      return /databases/$(database)/documents/crew_invitations/$(invitationId);
    }

    function isValidCrewName(name) {
      return name is string && name.size() >= 3 && name.size() <= 50;
    }

    function isValidCrewPayload() {
      return request.resource.data.keys().hasAll(['name', 'ownerId', 'createdAt']) &&
        isValidCrewName(request.resource.data.name) &&
        request.resource.data.ownerId is string &&
        request.resource.data.createdAt is timestamp;
    }

    function isValidCrewUpdate() {
      return isValidCrewPayload() &&
        request.resource.data.ownerId == resource.data.ownerId &&
        request.resource.data.createdAt == resource.data.createdAt;
    }

    function isValidMembershipPayload(membershipId) {
      return hasValidMembershipFields(membershipId) &&
        exists(userPath(request.resource.data.userId)) &&
        get(userPath(request.resource.data.userId)).data.username == request.resource.data.username &&
        get(userPath(request.resource.data.userId)).data.displayName == request.resource.data.displayName &&
        request.resource.data.get('avatarUrl', null) == get(userPath(request.resource.data.userId)).data.get('avatarUrl', null);
    }

    function hasValidMembershipFields(membershipId) {
      return request.resource.data.keys().hasAll([
          'crewId',
          'userId',
          'role',
          'joinedAt',
          'username',
          'displayName'
        ]) &&
        membershipId == request.resource.data.crewId + '_' + request.resource.data.userId &&
        request.resource.data.crewId is string &&
        request.resource.data.userId is string &&
        (request.resource.data.role == 'owner' || request.resource.data.role == 'member') &&
        request.resource.data.joinedAt is timestamp &&
        request.resource.data.username is string &&
        request.resource.data.displayName is string &&
        (
          !request.resource.data.keys().hasAny(['avatarUrl']) ||
          request.resource.data.avatarUrl == null ||
          request.resource.data.avatarUrl is string
        );
    }

    function isValidInvitationPayload(invitationId) {
      return request.resource.data.keys().hasAll([
          'crewId',
          'invitedUserId',
          'invitedByUserId',
          'createdAt',
          'crewName',
          'invitedByUsername',
          'invitedByDisplayName'
        ]) &&
        invitationId == request.resource.data.crewId + '_' + request.resource.data.invitedUserId &&
        request.resource.data.invitedByUserId == request.auth.uid &&
        request.resource.data.crewId is string &&
        request.resource.data.invitedUserId is string &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.crewName is string &&
        request.resource.data.invitedByUsername is string &&
        request.resource.data.invitedByDisplayName is string &&
        (
          !request.resource.data.keys().hasAny(['invitedUsername']) ||
          request.resource.data.invitedUsername is string
        ) &&
        exists(crewPath(request.resource.data.crewId)) &&
        exists(userPath(request.resource.data.invitedByUserId)) &&
        exists(userPath(request.resource.data.invitedUserId)) &&
        get(crewPath(request.resource.data.crewId)).data.name == request.resource.data.crewName &&
        get(userPath(request.resource.data.invitedByUserId)).data.username == request.resource.data.invitedByUsername &&
        get(userPath(request.resource.data.invitedByUserId)).data.displayName == request.resource.data.invitedByDisplayName &&
        (
          !request.resource.data.keys().hasAny(['invitedUsername']) ||
          get(userPath(request.resource.data.invitedUserId)).data.username == request.resource.data.invitedUsername
        );
    }

    function isCrewMember(crewId) {
      return signedIn() && exists(membershipPath(crewId + '_' + request.auth.uid));
    }

    function isCrewOwner(crewId) {
      return signedIn() &&
        exists(crewPath(crewId)) &&
        get(crewPath(crewId)).data.ownerId == request.auth.uid &&
        exists(ownerMembershipPath(crewId, request.auth.uid)) &&
        get(ownerMembershipPath(crewId, request.auth.uid)).data.role == 'owner';
    }

    function outingPath(outingId) {
      return /databases/$(database)/documents/outings/$(outingId);
    }

    function participantPath(participantId) {
      return /databases/$(database)/documents/outing_participants/$(participantId);
    }

    function chatMessagePath(messageId) {
      return /databases/$(database)/documents/chat_messages/$(messageId);
    }

    function isChatEligible(outingId) {
      return signedIn() &&
        exists(outingPath(outingId)) &&
        get(outingPath(outingId)).data.get('deletionPending', false) == false &&
        exists(membershipPath(get(outingPath(outingId)).data.crewId + '_' + request.auth.uid)) &&
        exists(participantPath(outingId + '_' + request.auth.uid));
    }

    function isChatWritable(outingId) {
      return isChatEligible(outingId) &&
        get(outingPath(outingId)).data.status in ['draft', 'planning', 'confirmed', 'meeting'];
    }

    function isValidChatCommand() {
      let outing = get(outingPath(request.resource.data.outingId)).data;
      return request.resource.data.keys().hasOnly([
          'type', 'outingId', 'crewId', 'requestedByUserId',
          'clientMessageId', 'payload', 'status', 'createdAt'
        ]) &&
        request.resource.data.keys().hasAll([
          'type', 'outingId', 'crewId', 'requestedByUserId',
          'clientMessageId', 'payload', 'status', 'createdAt'
        ]) &&
        request.resource.data.type == 'send_message' &&
        request.resource.data.outingId is string &&
        request.resource.data.crewId == outing.crewId &&
        request.resource.data.requestedByUserId == request.auth.uid &&
        request.resource.data.clientMessageId is string &&
        request.resource.data.clientMessageId.size() >= 16 &&
        request.resource.data.clientMessageId.size() <= 200 &&
        request.resource.data.payload is map &&
        request.resource.data.payload.keys().hasOnly(['text']) &&
        request.resource.data.payload.keys().hasAll(['text']) &&
        request.resource.data.payload.text is string &&
        request.resource.data.payload.text.size() >= 1 &&
        request.resource.data.payload.text.size() <= 4000 &&
        request.resource.data.status == 'pending' &&
        request.resource.data.createdAt == request.time &&
        isChatWritable(request.resource.data.outingId);
    }

    function isValidReadState(readStateId) {
      let message = get(chatMessagePath(request.resource.data.readThroughMessageId)).data;
      return request.resource.data.keys().hasOnly([
          'outingId', 'crewId', 'userId', 'readThroughAcceptedAt',
          'readThroughMessageId', 'cursorExpiresAt', 'updatedAt'
        ]) &&
        request.resource.data.keys().hasAll([
          'outingId', 'crewId', 'userId', 'readThroughAcceptedAt',
          'readThroughMessageId', 'cursorExpiresAt', 'updatedAt'
        ]) &&
        readStateId == request.resource.data.outingId + '_' + request.auth.uid &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.crewId == get(outingPath(request.resource.data.outingId)).data.crewId &&
        request.resource.data.readThroughAcceptedAt is timestamp &&
        request.resource.data.readThroughMessageId is string &&
        request.resource.data.cursorExpiresAt is timestamp &&
        request.resource.data.updatedAt == request.time &&
        isChatEligible(request.resource.data.outingId) &&
        exists(chatMessagePath(request.resource.data.readThroughMessageId)) &&
        message.outingId == request.resource.data.outingId &&
        message.crewId == request.resource.data.crewId &&
        message.acceptedAt == request.resource.data.readThroughAcceptedAt &&
        message.expiresAt == request.resource.data.cursorExpiresAt &&
        message.expiresAt > request.time;
    }

    function advancesReadState() {
      return request.resource.data.outingId == resource.data.outingId &&
        request.resource.data.crewId == resource.data.crewId &&
        request.resource.data.userId == resource.data.userId &&
        (
          request.resource.data.readThroughAcceptedAt > resource.data.readThroughAcceptedAt ||
          (
            request.resource.data.readThroughAcceptedAt == resource.data.readThroughAcceptedAt &&
            request.resource.data.readThroughMessageId > resource.data.readThroughMessageId
          )
        );
    }

    function isValidOutingString(value, min, max) {
      return value is string && value.size() >= min && value.size() <= max;
    }

    function isValidOutingStatus(status) {
      return status in ['draft', 'planning', 'confirmed', 'meeting', 'completed', 'archived', 'cancelled'];
    }

    function isValidUserProfile() {
      return request.resource.data.keys().hasAll([
          'username', 'displayName', 'createdAt'
        ]) &&
        request.resource.data.username is string &&
        request.resource.data.displayName is string &&
        request.resource.data.createdAt is timestamp &&
        (
          !request.resource.data.keys().hasAny(['avatarUrl']) ||
          request.resource.data.avatarUrl == null ||
          request.resource.data.avatarUrl is string
        );
    }

    function isValidUserProfileUpdate() {
      return isValidUserProfile() &&
        request.resource.data.username == resource.data.username &&
        request.resource.data.createdAt == resource.data.createdAt;
    }

    function matchesUpdatedUserProfile(uid) {
      return existsAfter(userPath(uid)) &&
        request.resource.data.username == getAfter(userPath(uid)).data.username &&
        request.resource.data.displayName == getAfter(userPath(uid)).data.displayName &&
        request.resource.data.get('avatarUrl', null) == getAfter(userPath(uid)).data.get('avatarUrl', null);
    }

    function isValidMembershipProfileUpdate() {
      return request.auth.uid == resource.data.userId &&
        request.resource.data.crewId == resource.data.crewId &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.joinedAt == resource.data.joinedAt &&
        hasValidMembershipFields(resource.data.crewId + '_' + resource.data.userId) &&
        matchesUpdatedUserProfile(resource.data.userId);
    }

    function keepsParticipantIdentity() {
      return request.resource.data.get('outingId', null) == resource.data.get('outingId', null) &&
        request.resource.data.get('crewId', null) == resource.data.get('crewId', null) &&
        request.resource.data.get('userId', null) == resource.data.get('userId', null) &&
        request.resource.data.get('addedByUserId', null) == resource.data.get('addedByUserId', null) &&
        request.resource.data.get('addedAt', null) == resource.data.get('addedAt', null) &&
        request.resource.data.get('isCreatorParticipant', null) == resource.data.get('isCreatorParticipant', null);
    }

    function isValidParticipantProfileUpdate() {
      return request.auth.uid == resource.data.userId &&
        keepsParticipantIdentity() &&
        request.resource.data.get('attendanceStatus', null) == resource.data.get('attendanceStatus', null) &&
        request.resource.data.get('respondedAt', null) == resource.data.get('respondedAt', null) &&
        matchesUpdatedUserProfile(resource.data.userId);
    }

    function agreementRoundPath(roundId) {
      return /databases/$(database)/documents/agreement_rounds/$(roundId);
    }
    function agreementProposalPath(proposalId) {
      return /databases/$(database)/documents/agreement_proposals/$(proposalId);
    }
    function isAcceptedParticipant(outingId) {
      let id = outingId + '_' + request.auth.uid;
      return signedIn() && exists(participantPath(id)) &&
        get(participantPath(id)).data.attendanceStatus == 'accepted';
    }
    function validVoteId(voteId) {
      return voteId == request.resource.data.roundId + '_' + request.resource.data.category + '_' + request.auth.uid;
    }
    function validVoteTarget() {
      let round = get(agreementRoundPath(request.resource.data.roundId)).data;
      let proposal = get(agreementProposalPath(request.resource.data.proposalId)).data;
      let outing = get(outingPath(round.outingId)).data;
      return request.resource.data.keys().hasOnly(['roundId','outingId','crewId','category','proposalId','userId','createdAt','updatedAt']) &&
        request.resource.data.keys().hasAll(['roundId','outingId','crewId','category','proposalId','userId','createdAt','updatedAt']) &&
        request.resource.data.roundId is string && request.resource.data.outingId is string &&
        request.resource.data.crewId is string && request.resource.data.proposalId is string &&
        request.resource.data.category in ['time','location'] && request.resource.data.userId == request.auth.uid &&
        round.status == 'open' && round.outingId == request.resource.data.outingId && round.crewId == request.resource.data.crewId &&
        outing.status == 'planning' && outing.activeAgreementRoundId == request.resource.data.roundId &&
        outing.get('deletionPending', false) == false &&
        proposal.roundId == request.resource.data.roundId && proposal.category == request.resource.data.category &&
        isCrewMember(round.crewId) && isAcceptedParticipant(round.outingId) &&
        (request.resource.data.category != 'time' || proposal.timeValue > request.time);
    }
    function validCommandPayload(type, payload) {
      return (type == 'open_round' && payload.keys().hasOnly([])) ||
        (type == 'create_proposal' && (
          (payload.keys().hasOnly(['category','timeValue']) &&
            payload.keys().hasAll(['category','timeValue']) &&
            payload.category == 'time' && payload.timeValue is timestamp &&
            payload.timeValue > request.time) ||
          (payload.keys().hasOnly(['category','locationText']) &&
            payload.keys().hasAll(['category','locationText']) &&
            payload.category == 'location' &&
            isValidOutingString(payload.locationText, 1, 120))
        )) ||
        (type == 'preview_confirmation' && payload.keys().hasOnly([])) ||
        (type == 'delete_outing' && payload.keys().hasOnly([])) ||
        (type == 'expire_outing' && payload.keys().hasOnly([])) ||
        (type == 'confirm_round' &&
          payload.keys().hasOnly(['selectedTimeProposalId','selectedLocationProposalId']) &&
          (!payload.keys().hasAny(['selectedTimeProposalId']) || payload.selectedTimeProposalId is string) &&
          (!payload.keys().hasAny(['selectedLocationProposalId']) || payload.selectedLocationProposalId is string)) ||
        ((type == 'reopen_round' || type == 'cancel_outing') &&
          payload.keys().hasOnly(['reason']) && payload.keys().hasAll(['reason']) &&
          isValidOutingString(payload.reason, 3, 200));
    }

    function isValidAttendanceUpdate() {
      return request.auth.uid == resource.data.userId &&
        isCrewMember(resource.data.crewId) &&
        get(outingPath(resource.data.outingId)).data.status in ['draft', 'planning', 'confirmed'] &&
        get(outingPath(resource.data.outingId)).data.get('deletionPending', false) == false &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'attendanceStatus', 'respondedAt'
        ]) &&
        request.resource.data.attendanceStatus in ['accepted', 'declined'] &&
        request.resource.data.respondedAt == request.time;
    }

    function isCrewMemberByUid(crewId, uid) {
      return signedIn() && exists(membershipPath(crewId + '_' + uid));
    }

    function isOutingCrewMember(outingId) {
      return signedIn() &&
        exists(outingPath(outingId)) &&
        isCrewMember(get(outingPath(outingId)).data.crewId);
    }

    function isOutingCreator(outingId) {
      return signedIn() &&
        exists(outingPath(outingId)) &&
        get(outingPath(outingId)).data.createdByUserId == request.auth.uid;
    }

    function isOutingManager(outingId) {
      return isOutingCreator(outingId) ||
        isCrewOwner(get(outingPath(outingId)).data.crewId);
    }

    function isValidTransition(fromStatus, toStatus) {
      return (
        (fromStatus == 'draft' && (toStatus == 'planning' || toStatus == 'cancelled')) ||
        (fromStatus == 'planning' && (toStatus == 'confirmed' || toStatus == 'cancelled')) ||
        (fromStatus == 'confirmed' && (toStatus == 'meeting' || toStatus == 'cancelled')) ||
        (fromStatus == 'meeting' && toStatus == 'completed') ||
        (fromStatus == 'completed' && toStatus == 'archived')
      );
    }

    function hasValidOutingShape() {
      return request.resource.data.keys().hasAll([
          'crewId', 'title', 'scheduledAt', 'locationText',
          'status', 'createdByUserId', 'createdAt', 'updatedAt'
          ,'agreementRoundSequence'
        ]) &&
        request.resource.data.crewId is string &&
        request.resource.data.createdByUserId is string &&
        isValidOutingStatus(request.resource.data.status) &&
        isValidOutingString(request.resource.data.title, 3, 80) &&
        isValidOutingString(request.resource.data.locationText, 1, 120) &&
        request.resource.data.scheduledAt is timestamp &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.updatedAt is timestamp &&
        request.resource.data.agreementRoundSequence is int &&
        request.resource.data.agreementRoundSequence >= 0 &&
        (
          !request.resource.data.keys().hasAny(['activeAgreementRoundId']) ||
          request.resource.data.activeAgreementRoundId == null ||
          request.resource.data.activeAgreementRoundId is string
        ) &&
        (
          !request.resource.data.keys().hasAny(['confirmedAgreementRoundId']) ||
          request.resource.data.confirmedAgreementRoundId == null ||
          request.resource.data.confirmedAgreementRoundId is string
        ) &&
        (
          !request.resource.data.keys().hasAny(['description']) ||
          isValidOutingString(request.resource.data.description, 0, 500)
        ) &&
        (
          request.resource.data.status == 'cancelled' ||
          (
            !request.resource.data.keys().hasAny(['cancelledReason']) &&
            !request.resource.data.keys().hasAny(['cancelledAt'])
          )
        ) &&
        (
          request.resource.data.status != 'cancelled' ||
          (
            isValidOutingString(request.resource.data.cancelledReason, 3, 200) &&
            request.resource.data.cancelledAt is timestamp
          )
        ) &&
        (
          request.resource.data.status == 'archived' ||
          !request.resource.data.keys().hasAny(['archivedAt'])
        ) &&
        (
          request.resource.data.status != 'archived' ||
          request.resource.data.archivedAt is timestamp
        );
    }

    function isValidOutingCreatePayload() {
      return hasValidOutingShape() &&
        request.resource.data.createdByUserId == request.auth.uid &&
        request.resource.data.status == 'draft' &&
        request.resource.data.agreementRoundSequence == 0 &&
        !request.resource.data.keys().hasAny([
          'activeAgreementRoundId', 'confirmedAgreementRoundId',
          'deletionPending'
        ]) &&
        exists(crewPath(request.resource.data.crewId)) &&
        isCrewMember(request.resource.data.crewId);
    }

    function keepsOutingIdentity() {
      return request.resource.data.crewId == resource.data.crewId &&
        request.resource.data.createdByUserId == resource.data.createdByUserId &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.agreementRoundSequence == resource.data.agreementRoundSequence &&
        request.resource.data.get('activeAgreementRoundId', null) == resource.data.get('activeAgreementRoundId', null) &&
        request.resource.data.get('confirmedAgreementRoundId', null) == resource.data.get('confirmedAgreementRoundId', null);
    }

    function isOutingDetailEdit() {
      return resource.data.status in ['draft', 'planning', 'confirmed', 'meeting'] &&
        request.resource.data.status == resource.data.status &&
        (
          (
            resource.data.status == 'draft' &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'title', 'description', 'scheduledAt', 'locationText', 'updatedAt'
            ])
          ) ||
          (
            resource.data.status in ['planning', 'confirmed', 'meeting'] &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'title', 'description', 'updatedAt'
            ])
          )
        );
    }

    function isOutingLifecycleEdit() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isValidTransition(resource.data.status, request.resource.data.status) &&
        (
          (
            resource.data.status == 'draft' &&
            request.resource.data.status == 'cancelled' &&
            changed.hasOnly([
              'status', 'cancelledReason', 'cancelledAt', 'updatedAt'
            ])
          ) ||
          (
            resource.data.status == 'confirmed' &&
            request.resource.data.status == 'meeting' &&
            changed.hasOnly(['status', 'updatedAt'])
          ) ||
          (
            resource.data.status == 'meeting' &&
            request.resource.data.status == 'completed' &&
            changed.hasOnly(['status', 'updatedAt'])
          ) ||
          (
            resource.data.status == 'completed' &&
            request.resource.data.status == 'archived' &&
            changed.hasOnly(['status', 'archivedAt', 'updatedAt'])
          )
        );
    }

    function isValidOutingUpdatePayload() {
      return hasValidOutingShape() &&
        keepsOutingIdentity() &&
        request.resource.data.crewId == resource.data.crewId &&
        (isOutingDetailEdit() || isOutingLifecycleEdit());
    }

    function isValidParticipantPayload(participantId) {
      return request.resource.data.keys().hasAll([
          'outingId', 'crewId', 'userId', 'username', 'displayName',
          'addedByUserId', 'addedAt', 'isCreatorParticipant',
          'attendanceStatus', 'respondedAt'
        ]) &&
        participantId == request.resource.data.outingId + '_' + request.resource.data.userId &&
        request.resource.data.outingId is string &&
        request.resource.data.crewId is string &&
        request.resource.data.userId is string &&
        request.resource.data.username is string &&
        request.resource.data.displayName is string &&
        request.resource.data.addedByUserId is string &&
        request.resource.data.addedAt is timestamp &&
        request.resource.data.isCreatorParticipant is bool &&
        (
          !request.resource.data.keys().hasAny(['avatarUrl']) ||
          request.resource.data.avatarUrl == null ||
          request.resource.data.avatarUrl is string
        ) &&
        request.resource.data.addedByUserId == request.auth.uid &&
        request.resource.data.attendanceStatus in ['invited', 'accepted', 'declined'] &&
        (
          (request.resource.data.isCreatorParticipant == true &&
            request.resource.data.attendanceStatus == 'accepted' &&
            request.resource.data.respondedAt is timestamp) ||
          (request.resource.data.isCreatorParticipant == false &&
            request.resource.data.attendanceStatus == 'invited' &&
            request.resource.data.respondedAt == null) ||
          (request.resource.data.isCreatorParticipant == false &&
            request.resource.data.userId == request.auth.uid &&
            request.resource.data.attendanceStatus in ['accepted', 'declined'] &&
            request.resource.data.respondedAt == request.time)
        ) &&
        (
          (
            exists(outingPath(request.resource.data.outingId)) &&
            get(outingPath(request.resource.data.outingId)).data.crewId == request.resource.data.crewId
          ) ||
          (
            !exists(outingPath(request.resource.data.outingId)) &&
            existsAfter(outingPath(request.resource.data.outingId)) &&
            getAfter(outingPath(request.resource.data.outingId)).data.crewId == request.resource.data.crewId
          )
        ) &&
        isCrewMemberByUid(request.resource.data.crewId, request.resource.data.userId) &&
        exists(userPath(request.resource.data.userId)) &&
        get(userPath(request.resource.data.userId)).data.username == request.resource.data.username &&
        get(userPath(request.resource.data.userId)).data.displayName == request.resource.data.displayName &&
        request.resource.data.get('avatarUrl', null) == get(userPath(request.resource.data.userId)).data.get('avatarUrl', null);
    }

    function isOutingSelfResponse() {
      return request.resource.data.userId == request.auth.uid &&
        request.resource.data.addedByUserId == request.auth.uid &&
        request.resource.data.isCreatorParticipant == false &&
        exists(outingPath(request.resource.data.outingId)) &&
        get(outingPath(request.resource.data.outingId)).data.status in ['draft', 'planning', 'confirmed'];
    }

    function isOwnerMembershipCreatedWithCrew(crewId) {
      return existsAfter(membershipPath(crewId + '_' + request.auth.uid));
    }

    function isNewCrewCreatedWithOwnerMembership(crewId) {
      return !exists(crewPath(crewId)) &&
        existsAfter(crewPath(crewId)) &&
        getAfter(crewPath(crewId)).data.ownerId == request.auth.uid;
    }

    function isInvitationConsumedWithMembership(membershipId) {
      return exists(invitationPath(membershipId)) &&
        !existsAfter(invitationPath(membershipId));
    }

    function isOwnerMembershipDeletedWithCrew(crewId) {
      return exists(ownerMembershipPath(crewId, resource.data.ownerId)) &&
        !existsAfter(ownerMembershipPath(crewId, resource.data.ownerId));
    }
    
    // User Profile Rules
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.auth.uid == uid &&
        isValidUserProfile();
      allow update: if request.auth != null &&
        request.auth.uid == uid &&
        isValidUserProfileUpdate();
      allow delete: if false; // Profiles cannot be deleted directly from client in MVP
    }
    
    // Username Registry Rules (Ensures Uniqueness)
    match /usernames/{username} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.keys().hasOnly(['uid']) &&
        request.resource.data.keys().hasAll(['uid']) &&
        request.resource.data.uid is string &&
        request.resource.data.uid == request.auth.uid;
      allow update, delete: if false; // Usernames are immutable
    }

    match /crews/{crewId} {
      allow read: if isCrewMember(crewId);

      allow create: if signedIn() &&
        isValidCrewPayload() &&
        request.resource.data.ownerId == request.auth.uid &&
        isOwnerMembershipCreatedWithCrew(crewId);

      allow update: if isCrewOwner(crewId) &&
        isValidCrewUpdate();

      allow delete: if isCrewOwner(crewId) &&
        isOwnerMembershipDeletedWithCrew(crewId);
    }

    match /crew_memberships/{membershipId} {
      allow read: if signedIn() &&
        (
          resource.data.userId == request.auth.uid ||
          isCrewMember(resource.data.crewId)
        );

      allow create: if signedIn() &&
        isValidMembershipPayload(membershipId) &&
        (
          (
            request.resource.data.role == 'owner' &&
            request.resource.data.userId == request.auth.uid &&
            isNewCrewCreatedWithOwnerMembership(request.resource.data.crewId)
          ) ||
          (
            request.resource.data.role == 'member' &&
            request.resource.data.userId == request.auth.uid &&
            isInvitationConsumedWithMembership(membershipId)
          )
        );

      allow update: if signedIn() && isValidMembershipProfileUpdate();

      allow delete: if signedIn() &&
        (
          (
            resource.data.userId == request.auth.uid &&
            resource.data.role == 'member'
          ) ||
          (
            isCrewOwner(resource.data.crewId) &&
            resource.data.role == 'member'
          ) ||
          (
            isCrewOwner(resource.data.crewId) &&
            resource.data.role == 'owner' &&
            !existsAfter(crewPath(resource.data.crewId))
          )
        );
    }

    match /crew_invitations/{invitationId} {
      allow read: if signedIn() &&
        (
          resource.data.invitedUserId == request.auth.uid ||
          isCrewOwner(resource.data.crewId)
        );

      allow create: if signedIn() &&
        isValidInvitationPayload(invitationId) &&
        isCrewOwner(request.resource.data.crewId) &&
        exists(/databases/$(database)/documents/users/$(request.resource.data.invitedUserId)) &&
        !exists(membershipPath(invitationId));

      allow update: if false;

      allow delete: if signedIn() &&
        (
          resource.data.invitedUserId == request.auth.uid ||
          isCrewOwner(resource.data.crewId)
        );
    }

    match /outings/{outingId} {
      allow read: if isCrewMember(resource.data.crewId);
      allow create: if signedIn() &&
        isValidOutingCreatePayload() &&
        existsAfter(participantPath(outingId + '_' + request.auth.uid));
      allow update: if isOutingManager(outingId) &&
        isValidOutingUpdatePayload();
      allow delete: if false;
    }

    match /outing_participants/{participantId} {
      allow read: if isOutingCrewMember(resource.data.outingId);
      allow create: if signedIn() &&
        isValidParticipantPayload(participantId) &&
        (
          (
            request.resource.data.isCreatorParticipant == true &&
            request.resource.data.userId == request.auth.uid &&
            !exists(outingPath(request.resource.data.outingId)) &&
            existsAfter(outingPath(request.resource.data.outingId)) &&
            getAfter(outingPath(request.resource.data.outingId)).data.createdByUserId == request.auth.uid
          ) ||
          isOutingManager(request.resource.data.outingId) ||
          isOutingSelfResponse()
        );
      allow update: if signedIn() &&
        (isValidParticipantProfileUpdate() || isValidAttendanceUpdate());
      allow delete: if signedIn() &&
        (
          isOutingManager(resource.data.outingId) ||
          (
            resource.data.userId == request.auth.uid &&
            !existsAfter(membershipPath(resource.data.crewId + '_' + request.auth.uid))
          )
        );
    }

    match /agreement_rounds/{roundId} {
      allow read: if isCrewMember(resource.data.crewId);
      allow write: if false;
    }
    match /agreement_proposals/{proposalId} {
      allow read: if isCrewMember(resource.data.crewId);
      allow write: if false;
    }
    match /agreement_votes/{voteId} {
      allow get: if signedIn() && resource.data.userId == request.auth.uid;
      allow list: if false;
      allow create: if validVoteId(voteId) && validVoteTarget() &&
        request.resource.data.createdAt == request.time && request.resource.data.updatedAt == request.time;
      allow update: if validVoteId(voteId) && validVoteTarget() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['proposalId','updatedAt']) &&
        request.resource.data.createdAt == resource.data.createdAt && request.resource.data.updatedAt == request.time;
      allow delete: if signedIn() && resource.data.userId == request.auth.uid &&
        get(agreementRoundPath(resource.data.roundId)).data.status == 'open' &&
        isCrewMember(resource.data.crewId) && isAcceptedParticipant(resource.data.outingId);
    }
    match /agreement_results/{resultId} {
      allow read: if isCrewMember(resource.data.crewId) &&
        get(agreementRoundPath(resource.data.roundId)).data.status != 'open';
      allow write: if false;
    }
    match /agreement_commands/{commandId} {
      allow create: if signedIn() && request.resource.data.keys().hasOnly([
          'type','outingId','crewId','requestedByUserId','payload','status','createdAt']) &&
        request.resource.data.keys().hasAll(['type','outingId','crewId','requestedByUserId','payload','status','createdAt']) &&
        request.resource.data.type is string && request.resource.data.outingId is string &&
        request.resource.data.crewId is string && request.resource.data.requestedByUserId is string &&
        request.resource.data.payload is map &&
        request.resource.data.requestedByUserId == request.auth.uid && request.resource.data.status == 'pending' &&
        request.resource.data.createdAt == request.time &&
        get(outingPath(request.resource.data.outingId)).data.crewId == request.resource.data.crewId &&
        isCrewMember(request.resource.data.crewId) &&
        (request.resource.data.type in ['delete_outing', 'expire_outing'] ||
          get(outingPath(request.resource.data.outingId)).data.get('deletionPending', false) == false) &&
        (request.resource.data.type != 'delete_outing' || isOutingCreator(request.resource.data.outingId)) &&
        validCommandPayload(request.resource.data.type, request.resource.data.payload);
      allow get, list: if signedIn() && resource.data.requestedByUserId == request.auth.uid;
      allow update, delete: if false;
    }

    match /chat_messages/{messageId} {
      allow get: if isChatEligible(resource.data.outingId) &&
        resource.data.expiresAt > request.time;
      allow list: if isChatEligible(resource.data.outingId) &&
        request.query.limit != null &&
        request.query.limit <= 5000;
      allow create, update, delete: if false;
    }

    match /chat_commands/{commandId} {
      allow create: if signedIn() && isValidChatCommand();
      allow get, list: if signedIn() &&
        resource.data.requestedByUserId == request.auth.uid;
      allow update, delete: if false;
    }

    match /chat_read_states/{readStateId} {
      allow get, list: if signedIn() &&
        resource.data.userId == request.auth.uid &&
        isChatEligible(resource.data.outingId);
      allow create: if signedIn() && isValidReadState(readStateId);
      allow update: if signedIn() &&
        isValidReadState(readStateId) &&
        advancesReadState();
      allow delete: if false;
    }

    match /chat_rate_limits/{bucketId} {
      allow read, write: if false;
    }

    match /chat_time_probes/{probeId} {
      allow create: if signedIn() &&
        probeId.matches('^' + request.auth.uid + '_.+$') &&
        request.resource.data.keys().hasOnly(['userId', 'requestedAt']) &&
        request.resource.data.keys().hasAll(['userId', 'requestedAt']) &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.requestedAt == request.time;
      allow get, delete: if signedIn() &&
        resource.data.userId == request.auth.uid;
      allow list, update: if false;
    }
  }
}
